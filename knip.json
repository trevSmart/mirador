{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": [
    "-lintignore"
  ],
  "entry": [
    "vite.config.ts",
    "vitest.setup.ts",
    "scripts/*.{js,mjs}",
    "src/main.tsx",
    "src/**/*.test.{ts,tsx}"
  ],
  "ignore": [
    "dist/**",
    "docs/**",
    "tmp/**",
    "force-app/**"
  ],
  "ignoreDependencies": [
    "@fontsource/inter",
    "@fontsource/jetbrains-mono",
    "@fontsource/space-grotesk"
  ]
}
